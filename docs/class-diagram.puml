@startuml
title Ice Sliding Puzzle Solver - Class Diagram

skinparam classAttributeIconSize 0
skinparam packageStyle rectangle

package "Core Model" {
  class Position {
    +int row
    +int col
    +Position()
    +Position(row: int, col: int)
    +operator==(other: Position): bool
    +operator!=(other: Position): bool
    +toString(): string
  }

  enum Direction {
    Up
    Down
    Left
    Right
  }

  enum TileType {
    Path
    Wall
    Lava
    Start
    Goal
    Numbered
  }

  class DirectionUtil {
    +getDelta(dir: Direction): Position
    +directionToChar(dir: Direction): char
    +directionToString(dir: Direction): string
  }

  class Tile {
    -TileType type
    -char symbol
    -int numberValue
    -int cost
    +Tile()
    +Tile(type: TileType, symbol: char, cost: int)
    +getType(): TileType
    +getSymbol(): char
    +getCost(): int
    +getNumberValue(): int
    +setCost(cost: int): void
    +isWall(): bool
    +isLava(): bool
    +isWalkable(): bool
    +isNumbered(): bool
    +isGoal(): bool
    +displayChar(): char
  }

  class Board {
    -int rows
    -int cols
    -vector<vector<Tile>> grid
    -Position startPosition
    -Position goalPosition
    -int maxNumber
    +Board()
    +Board(rows: int, cols: int)
    +isInside(pos: Position): bool
    +getTile(pos: Position): Tile
    +setTile(pos: Position, tile: Tile): void
    +getStartPosition(): Position
    +getGoalPosition(): Position
    +getRows(): int
    +getCols(): int
    +getMaxNumber(): int
    +setStartPosition(pos: Position): void
    +setGoalPosition(pos: Position): void
    +setMaxNumber(value: int): void
    +validate(): void
    +toString(): string
    +toStringWithActor(actor: Position): string
  }

  class PuzzleState {
    +Position actorPosition
    +int nextRequiredNumber
    +PuzzleState()
    +PuzzleState(actor: Position, nextNumber: int)
    +isGoalState(board: Board): bool
    +hash(): string
    +operator==(other: PuzzleState): bool
  }

  class MoveResult {
    +bool valid
    +bool gameOver
    +Direction direction
    +PuzzleState nextState
    +int movementCost
    +vector<Position> passedTiles
    +string reason
    +invalid(reason: string): MoveResult
    +gameOverResult(reason: string): MoveResult
  }

  class MovementSimulator {
    -Board board
    +MovementSimulator(board: Board)
    +slide(state: PuzzleState, dir: Direction): MoveResult
    -violatesNumberRule(tile: Tile, nextRequiredNumber: int): bool
    -updateNextRequiredNumber(tile: Tile, currentNextNumber: int): int
  }
}

package "Input Output" {
  class InputParser {
    -InputValidator validator
    +parseFromFile(path: string): Board
    -readLines(path: string): vector<string>
    -parseDimension(line: string): pair<int,int>
    -parseBoard(lines: vector<string>, rows: int, cols: int): Board
    -parseCosts(lines: vector<string>, board: Board): void
  }

  class InputValidator {
    +validateDimension(rows: int, cols: int): void
    +validateBoardRows(boardLines: vector<string>, rows: int, cols: int): void
    +validateCostRows(costs: vector<vector<int>>, rows: int, cols: int): void
    +validateRequiredSymbols(board: Board): void
    +validateNumberSequence(board: Board): void
    +validateSymbol(symbol: char): void
  }

  class SolutionWriter {
    +saveSolution(path: string, result: SearchResult, board: Board): void
    +saveIterations(path: string, steps: vector<SearchStep>): void
    -writeBoardStep(board: Board, state: PuzzleState): string
  }

  class Logger {
    +info(message: string): void
    +error(message: string): void
    +success(message: string): void
    +warning(message: string): void
  }
}

package "Search Model" {
  class SearchNode {
    +PuzzleState state
    +shared_ptr<SearchNode> parent
    +Direction moveFromParent
    +int gCost
    +int hCost
    +int fCost
    +int depth
    +SearchNode()
    +SearchNode(state: PuzzleState)
    +buildMovePath(): vector<Direction>
    +buildStatePath(): vector<PuzzleState>
  }

  class SearchStep {
    +int iteration
    +PuzzleState currentState
    +vector<PuzzleState> frontierStates
    +vector<PuzzleState> visitedStates
    +int gCost
    +int hCost
    +int fCost
    +string algorithmName
    +toString(board: Board): string
  }

  class SearchResult {
    +bool found
    +string algorithmName
    +string heuristicName
    +vector<Direction> moves
    +vector<PuzzleState> states
    +vector<SearchStep> iterations
    +int totalCost
    +int iterationCount
    +double executionTimeMs
    +string message
    +getMoveString(): string
    +hasSolution(): bool
  }

  class StateHasher {
    +operator()(state: PuzzleState): size_t
  }

  enum SearchStrategy {
    UCS
    GBFS
    ASTAR
    WEIGHTED_ASTAR
  }

  class NodeComparator {
    -SearchStrategy strategy
    +NodeComparator(strategy: SearchStrategy)
    +operator()(a: SearchNode, b: SearchNode): bool
  }
}

package "Heuristic" {
  abstract class Heuristic {
    +calculate(board: Board, state: PuzzleState): int
    +name(): string
  }

  class ManhattanHeuristic {
    +calculate(board: Board, state: PuzzleState): int
    +name(): string
    -findCurrentTarget(board: Board, state: PuzzleState): Position
  }

  class SlidingMoveHeuristic {
    +calculate(board: Board, state: PuzzleState): int
    +name(): string
    -estimateSlidingMoves(board: Board, from: Position, to: Position): int
  }

  class CostAwareHeuristic {
    -int minTileCost
    +CostAwareHeuristic(board: Board)
    +calculate(board: Board, state: PuzzleState): int
    +name(): string
    -findMinTileCost(board: Board): int
  }

  class CheckpointHeuristic {
    +calculate(board: Board, state: PuzzleState): int
    +name(): string
    -estimateRemainingCheckpoints(board: Board, state: PuzzleState): int
  }

  class HeuristicFactory {
    +create(heuristicName: string, board: Board): unique_ptr<Heuristic>
    +availableHeuristics(): vector<string>
  }
}

package "Pathfinding Algorithms" {
  abstract class IPathfinder {
    +solve(board: Board, heuristic: Heuristic): SearchResult
    +name(): string
  }

  class SearchEngine {
    -MovementSimulator simulator
    +SearchEngine(board: Board)
    +expandNode(node: SearchNode, board: Board, heuristic: Heuristic): vector<shared_ptr<SearchNode>>
    +shouldRelaxState(state: PuzzleState, newCost: int, bestCost: unordered_map): bool
    +createSearchStep(iteration: int, node: SearchNode, frontier: vector<PuzzleState>, visited: vector<PuzzleState>, algorithmName: string): SearchStep
  }

  class UniformCostSearch {
    +solve(board: Board, heuristic: Heuristic): SearchResult
    +name(): string
  }

  class GreedyBestFirstSearch {
    +solve(board: Board, heuristic: Heuristic): SearchResult
    +name(): string
  }

  class AStarSearch {
    +solve(board: Board, heuristic: Heuristic): SearchResult
    +name(): string
  }

  class WeightedAStarSearch {
    -double weight
    +WeightedAStarSearch(weight: double)
    +solve(board: Board, heuristic: Heuristic): SearchResult
    +name(): string
  }

  class PathfinderFactory {
    +create(algorithmName: string): unique_ptr<IPathfinder>
    +availableAlgorithms(): vector<string>
  }
}

package "Visualization and Playback" {
  class BoardRenderer {
    +renderBoard(board: Board): string
    +renderBoardWithState(board: Board, state: PuzzleState): string
    +renderSolutionStep(board: Board, result: SearchResult, stepIndex: int): string
    +renderSearchStep(board: Board, step: SearchStep): string
  }

  class PlaybackController {
    -vector<SearchStep> steps
    -int currentIndex
    -double speedMultiplier
    -bool playing
    +PlaybackController()
    +setSteps(steps: vector<SearchStep>): void
    +next(): void
    +previous(): void
    +jumpTo(index: int): void
    +play(): void
    +pause(): void
    +setSpeed(speed: double): void
    +getCurrentStep(): SearchStep
    +getCurrentIndex(): int
    +isPlaying(): bool
  }

  class CliPlaybackView {
    -BoardRenderer renderer
    -PlaybackController controller
    +run(board: Board, result: SearchResult): void
    -handleInput(): void
    -displayCurrentStep(board: Board): void
  }
}

package "CLI Application" {
  class CliApp {
    -InputParser inputParser
    -PathfinderFactory pathfinderFactory
    -HeuristicFactory heuristicFactory
    -BoardRenderer renderer
    -SolutionWriter solutionWriter
    -Logger logger
    +run(): void
    -askInputFile(): string
    -askAlgorithm(): string
    -askHeuristic(): string
    -askYesNo(question: string): bool
    -displayResult(board: Board, result: SearchResult): void
    -handleSaveSolution(board: Board, result: SearchResult): void
    -handlePlayback(board: Board, result: SearchResult): void
  }
}

package "GUI Bonus" {
  class GuiState {
    +Board board
    +SearchResult result
    +string selectedAlgorithm
    +string selectedHeuristic
    +string inputFilePath
    +bool hasBoardLoaded
    +bool hasResult
    +bool isPlayingPlayback
    +int currentStep
    +double playbackSpeed
    +reset(): void
    +canRunSolver(): bool
    +canPlayback(): bool
  }

  class GuiApp {
    -GuiState state
    -GuiBoardView boardView
    -GuiControlPanel controlPanel
    -GuiPlaybackPanel playbackPanel
    +run(): void
    -handleEvents(): void
    -update(deltaTime: double): void
    -render(): void
  }

  class GuiBoardView {
    -float tileSize
    -float offsetX
    -float offsetY
    -BoardRenderer renderer
    +draw(board: Board, state: PuzzleState): void
    +drawTile(tile: Tile, pos: Position): void
    +drawActor(pos: Position): void
    +fitToWindow(rows: int, cols: int, windowWidth: int, windowHeight: int): void
  }

  class GuiControlPanel {
    +draw(): void
    +handleEvent(state: GuiState): void
    +isSolveClicked(): bool
    +isLoadFileClicked(): bool
    +isSaveClicked(): bool
  }

  class GuiPlaybackPanel {
    -PlaybackController controller
    +draw(state: GuiState): void
    +handleEvent(state: GuiState): void
    +nextStep(): void
    +previousStep(): void
    +jumpToStep(step: int): void
    +setSpeed(speed: double): void
  }

  class AnimationController {
    -Position from
    -Position to
    -float progress
    -float duration
    -bool active
    +start(from: Position, to: Position, duration: float): void
    +update(deltaTime: float): void
    +getInterpolatedPosition(): Position
    +isFinished(): bool
  }
}

package "Utility" {
  class Timer {
    -time_point startTime
    +start(): void
    +stopMs(): double
  }

  class PuzzleException {
    #string message
    +PuzzleException(message: string)
    +what(): const char*
  }

  class InputException
  class ValidationException
  class SolverException
  class FileException
}

' Relationships - Core
Board "1" *-- "many" Tile
Board --> Position
PuzzleState --> Position
MoveResult --> PuzzleState
MoveResult --> Direction
MoveResult --> Position
MovementSimulator --> Board
MovementSimulator --> MoveResult
MovementSimulator --> PuzzleState
DirectionUtil --> Direction
DirectionUtil --> Position
Tile --> TileType

' Relationships - IO
InputParser --> InputValidator
InputParser --> Board
InputValidator --> Board
SolutionWriter --> SearchResult
SolutionWriter --> SearchStep
SolutionWriter --> Board

' Relationships - Search
SearchNode --> PuzzleState
SearchNode --> Direction
SearchNode --> SearchNode : parent
SearchStep --> PuzzleState
SearchResult *-- SearchStep
SearchResult --> Direction
SearchResult --> PuzzleState
StateHasher --> PuzzleState
NodeComparator --> SearchStrategy
NodeComparator --> SearchNode

' Relationships - Heuristic
Heuristic <|-- ManhattanHeuristic
Heuristic <|-- SlidingMoveHeuristic
Heuristic <|-- CostAwareHeuristic
Heuristic <|-- CheckpointHeuristic
HeuristicFactory ..> Heuristic
ManhattanHeuristic --> Board
SlidingMoveHeuristic --> Board
CostAwareHeuristic --> Board
CheckpointHeuristic --> Board

' Relationships - Algorithms
IPathfinder <|-- UniformCostSearch
IPathfinder <|-- GreedyBestFirstSearch
IPathfinder <|-- AStarSearch
IPathfinder <|-- WeightedAStarSearch
PathfinderFactory ..> IPathfinder
UniformCostSearch --> SearchEngine
GreedyBestFirstSearch --> SearchEngine
AStarSearch --> SearchEngine
WeightedAStarSearch --> SearchEngine
SearchEngine --> MovementSimulator
SearchEngine --> SearchNode
SearchEngine --> SearchStep
SearchEngine --> Heuristic

' Relationships - Visualization
BoardRenderer --> Board
BoardRenderer --> PuzzleState
BoardRenderer --> SearchResult
BoardRenderer --> SearchStep
PlaybackController *-- SearchStep
CliPlaybackView --> BoardRenderer
CliPlaybackView --> PlaybackController
CliPlaybackView --> SearchResult

' Relationships - CLI
CliApp --> InputParser
CliApp --> PathfinderFactory
CliApp --> HeuristicFactory
CliApp --> BoardRenderer
CliApp --> SolutionWriter
CliApp --> Logger
CliApp --> CliPlaybackView
CliApp --> IPathfinder
CliApp --> Heuristic
CliApp --> SearchResult

' Relationships - GUI
GuiApp *-- GuiState
GuiApp *-- GuiBoardView
GuiApp *-- GuiControlPanel
GuiApp *-- GuiPlaybackPanel
GuiState --> Board
GuiState --> SearchResult
GuiBoardView --> BoardRenderer
GuiBoardView --> Tile
GuiBoardView --> Position
GuiControlPanel --> GuiState
GuiPlaybackPanel --> PlaybackController
GuiPlaybackPanel --> GuiState
AnimationController --> Position

' Relationships - Utility
PuzzleException <|-- InputException
PuzzleException <|-- ValidationException
PuzzleException <|-- SolverException
PuzzleException <|-- FileException

@enduml